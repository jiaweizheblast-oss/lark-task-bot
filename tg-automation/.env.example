APP_ENV=development
APP_NAME=NEXUS TG Automation Centre
DATABASE_URL=sqlite:///./tg_automation.db
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Asia/Kolkata
GLOBAL_SENDING_ENABLED=false
TELEGRAM_TEST_SENDING_ENABLED=false
EMBEDDED_WORKER_ENABLED=false
MEDIA_STORAGE_DIR=

# Real values belong only in secret storage or a local .env.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=Game21HubBot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_ADMIN_USER_IDS=
TELEGRAM_TEST_CHANNEL_ID=
TELEGRAM_TEST_GROUP_ID=
NEXUS_ADMIN_URL=http://localhost:3000

TRACKING_BASE_URL=http://localhost:8000/r
SUPPORT_URL=https://t.me/example_support
PROMOTIONS_URL=https://example.com/promotions
TRACKING_ALLOWED_HOSTS=example.com,app.21.game,galioss.godown.vip,ln.run,t.me

# Enable in staging/production and store each key in a secret manager.
API_AUTH_ENABLED=false
NEXUS_OPERATOR_API_KEY=
NEXUS_ADMIN_API_KEY=

WORKER_POLL_SECONDS=2
WORKER_ERROR_BACKOFF_SECONDS=10
WORKER_BATCH_SIZE=20
