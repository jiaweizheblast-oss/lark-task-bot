# Railway service-variable template.
# Never commit real credentials. Replace every REPLACE_* value in Railway.

# Task Bot credentials.
APP_ID=cli_REPLACE_WITH_TASK_BOT_APP_ID
APP_SECRET=REPLACE_WITH_TASK_BOT_APP_SECRET
BOT_NAME=Task Bot

# Recruitment Bot credentials. Keep this application separate from Task Bot.
RECRUITMENT_LARK_APP_ID=cli_REPLACE_WITH_RECRUITMENT_BOT_APP_ID
RECRUITMENT_LARK_APP_SECRET=REPLACE_WITH_RECRUITMENT_BOT_APP_SECRET
RECRUITMENT_BOT_NAME=RECRUITMENT BOT

# International Lark. For mainland Feishu use https://open.feishu.cn.
LARK_DOMAIN=https://open.larksuite.com

# Lark event subscription credentials.
ENCRYPT_KEY=REPLACE_WITH_EVENT_ENCRYPT_KEY
VERIFICATION_TOKEN=REPLACE_WITH_EVENT_VERIFICATION_TOKEN

# Railway injects DATABASE_URL when PostgreSQL is attached.
# DATABASE_URL=postgresql://user:password@host:5432/database

# One-time manager bootstrap code and panel password.
ADMIN_SETUP_CODE=REPLACE_WITH_RANDOM_ONE_TIME_SETUP_CODE
ADMIN_PANEL_PASSWORD=REPLACE_WITH_RANDOM_MANAGER_PASSWORD

# Reminder policy.
OVERDUE_ESCALATE_DAYS=2

# webhook is the supported Railway mode. ws is only for a supported long-lived
# local process.
MODE=webhook

# AI Talent Discovery -> Nexus read-only snapshot HMAC key. Both services use
# the same random value of at least 32 bytes.
NEXUS_INTEGRATION_SIGNING_KEY=REPLACE_WITH_RANDOM_32_BYTE_OR_LONGER_VALUE

# Railway search queue -> local Windows worker bearer token. Use a different
# random value of at least 32 bytes; never reuse the signing key.
NEXUS_TALENT_WORKER_TOKEN=REPLACE_WITH_DIFFERENT_RANDOM_32_BYTE_OR_LONGER_VALUE

# NEXUS -> TG Automation private Railway service connection.
TG_AUTOMATION_API_URL=
TG_AUTOMATION_API_KEY=

# Optional Lark open_id for private manager notifications.
ADMIN_NOTIFY_OPEN_ID=

# PORT is provided automatically by Railway.
